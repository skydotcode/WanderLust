<% if (locals.success && locals.success.length) {%>
<div class="alert col-6 offset-3 alert-success alert-dismissible fade show" role="alert">

  <%= locals.success %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

<% } %>

<% if (error && error.length) {%>
<div class="alert col-6 offset-3 alert-danger alert-dismissible fade show" role="alert">

  <%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>